generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PersonGender {
  MALE
  FEMALE
}

enum PersonStatus {
  ACTIVE
  INACTIVE
}

enum AdminRole {
  ADMIN
  SUPERADMIN
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}

enum RelationshipType {
  MARRIAGE
  PARENT_CHILD
  ADMIN_EXCEPTION
}

enum RelationshipDirection {
  BIDIRECTIONAL
  PARENT_TO_CHILD
  CHILD_TO_PARENT
}

enum ZoneStatus {
  ACTIVE
  INACTIVE
}

enum TemplateStatus {
  ACTIVE
  INACTIVE
}

enum ShiftStatus {
  OPEN
  BLOCKED
  FULL
  CLOSED
}

enum ShiftBlockType {
  SPECIFIC_SHIFT
  FULL_DATE
  ZONE
  DATE_RANGE
}

enum ShiftRequestStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum AssignmentStatus {
  CONFIRMED
  CANCELLED
  REPLACED
}

enum HistoryVisibility {
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR
  TWO_YEARS
  UNLIMITED
}

enum AuditActorType {
  ADMIN
  PUBLIC_PERSON
  SYSTEM
}

model Person {
  id                     String                  @id @default(uuid()) @db.Uuid
  firstName              String                  @map("first_name")
  lastName               String                  @map("last_name")
  gender                 PersonGender
  status                 PersonStatus            @default(ACTIVE)
  phone                  String?                 @db.VarChar(30)
  email                  String?                 @db.VarChar(255)
  notes                  String?
  pinHash                String                  @map("pin_hash")
  failedPinAttempts      Int                     @default(0) @map("failed_pin_attempts")
  pinLockedUntil         DateTime?               @map("pin_locked_until") @db.Timestamptz(6)
  pinUpdatedAt           DateTime?               @map("pin_updated_at") @db.Timestamptz(6)
  lastParticipationAt    DateTime?               @map("last_participation_at") @db.Timestamptz(6)
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  availabilityExceptions AvailabilityException[]
  requests               ShiftRequest[]          @relation("ShiftRequestPerson")
  suggestedInRequests    ShiftRequest[]          @relation("ShiftRequestSuggestedPartner")
  assignmentSlotsOne     Assignment[]            @relation("AssignmentPersonOne")
  assignmentSlotsTwo     Assignment[]            @relation("AssignmentPersonTwo")
  relationshipsAsPersonA Relationship[]          @relation("RelationshipPersonA")
  relationshipsAsPersonB Relationship[]          @relation("RelationshipPersonB")
  auditLogsAsActor       AuditLog[]              @relation("AuditLogActorPerson")

  @@index([status])
  @@index([lastName, firstName])
  @@map("people")
}

model AdminUser {
  id                           String                  @id @default(uuid()) @db.Uuid
  authProviderId               String                  @unique @map("auth_provider_id")
  role                         AdminRole
  status                       AdminStatus             @default(ACTIVE)
  displayName                  String                  @map("display_name")
  email                        String                  @unique
  createdAt                    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdRelationships         Relationship[]
  createdShiftBlocks           ShiftBlock[]
  createdAvailabilityRecords   AvailabilityException[] @relation("AvailabilityCreatedByAdmin")
  decidedAssignments           Assignment[]
  updatedSystemConfigs         SystemConfig[]          @relation("SystemConfigUpdatedByAdmin")
  auditLogsAsActor             AuditLog[]              @relation("AuditLogActorAdmin")

  @@index([role, status])
  @@map("admin_users")
}

model Relationship {
  id               String                @id @default(uuid()) @db.Uuid
  personAId        String                @map("person_a_id") @db.Uuid
  personBId        String                @map("person_b_id") @db.Uuid
  type             RelationshipType
  direction        RelationshipDirection @default(BIDIRECTIONAL)
  notes            String?
  createdByAdminId String?               @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  personA          Person                @relation("RelationshipPersonA", fields: [personAId], references: [id], onDelete: Cascade)
  personB          Person                @relation("RelationshipPersonB", fields: [personBId], references: [id], onDelete: Cascade)
  createdByAdmin   AdminUser?            @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@unique([personAId, personBId, type])
  @@index([type])
  @@map("relationships")
}

model Zone {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @unique
  description   String?
  status        ZoneStatus      @default(ACTIVE)
  publicVisible Boolean         @default(true) @map("public_visible")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  templates     ShiftTemplate[]
  shifts        Shift[]
  blocks        ShiftBlock[]

  @@index([status, publicVisible])
  @@map("zones")
}

model ShiftTemplate {
  id         String         @id @default(uuid()) @db.Uuid
  zoneId     String         @map("zone_id") @db.Uuid
  dayOfWeek  Int            @map("day_of_week")
  startTime  DateTime       @map("start_time") @db.Time(6)
  endTime    DateTime       @map("end_time") @db.Time(6)
  status     TemplateStatus @default(ACTIVE)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  zone       Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  shifts     Shift[]

  @@unique([zoneId, dayOfWeek, startTime, endTime])
  @@index([zoneId, status])
  @@map("shift_templates")
}

model Shift {
  id         String           @id @default(uuid()) @db.Uuid
  zoneId     String           @map("zone_id") @db.Uuid
  templateId String?          @map("template_id") @db.Uuid
  shiftDate  DateTime         @map("shift_date") @db.Date
  startTime  DateTime         @map("start_time") @db.Time(6)
  endTime    DateTime         @map("end_time") @db.Time(6)
  status     ShiftStatus      @default(OPEN)
  generated  Boolean          @default(true)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  zone       Zone             @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  template   ShiftTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  requests   ShiftRequest[]
  assignments Assignment[]
  blocks     ShiftBlock[]

  @@unique([zoneId, shiftDate, startTime, endTime])
  @@index([shiftDate, status])
  @@index([zoneId, shiftDate])
  @@map("shifts")
}

model ShiftBlock {
  id               String         @id @default(uuid()) @db.Uuid
  zoneId           String?        @map("zone_id") @db.Uuid
  shiftId          String?        @map("shift_id") @db.Uuid
  startDate        DateTime       @map("start_date") @db.Date
  endDate          DateTime       @map("end_date") @db.Date
  blockType        ShiftBlockType @map("block_type")
  reason           String
  createdByAdminId String?        @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  zone             Zone?          @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  shift            Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  createdByAdmin   AdminUser?     @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([blockType, startDate, endDate])
  @@index([zoneId, startDate])
  @@index([shiftId])
  @@map("shift_blocks")
}

model AvailabilityException {
  id               String     @id @default(uuid()) @db.Uuid
  personId         String     @map("person_id") @db.Uuid
  startDate        DateTime   @map("start_date") @db.Date
  endDate          DateTime   @map("end_date") @db.Date
  reason           String
  notes            String?
  createdByAdminId String?    @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  person           Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdByAdmin   AdminUser? @relation("AvailabilityCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([personId, startDate, endDate])
  @@map("availability_exceptions")
}

model ShiftRequest {
  id                 String             @id @default(uuid()) @db.Uuid
  shiftId            String             @map("shift_id") @db.Uuid
  personId           String             @map("person_id") @db.Uuid
  suggestedPartnerId String?            @map("suggested_partner_id") @db.Uuid
  status             ShiftRequestStatus @default(PENDING)
  comments           String?
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  cancelledAt        DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  resolvedAt         DateTime?          @map("resolved_at") @db.Timestamptz(6)
  shift              Shift              @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  person             Person             @relation("ShiftRequestPerson", fields: [personId], references: [id], onDelete: Cascade)
  suggestedPartner   Person?            @relation("ShiftRequestSuggestedPartner", fields: [suggestedPartnerId], references: [id], onDelete: SetNull)

  @@index([shiftId, status])
  @@index([personId, status])
  @@index([suggestedPartnerId])
  @@map("shift_requests")
}

model Assignment {
  id                    String           @id @default(uuid()) @db.Uuid
  shiftId               String           @map("shift_id") @db.Uuid
  person1Id             String           @map("person_1_id") @db.Uuid
  person2Id             String           @map("person_2_id") @db.Uuid
  status                AssignmentStatus @default(CONFIRMED)
  ruleExceptionUsed     Boolean          @default(false) @map("rule_exception_used")
  exceptionReason       String?          @map("exception_reason")
  decidedByAdminId      String?          @map("decided_by_admin_id") @db.Uuid
  confirmedAt           DateTime?        @map("confirmed_at") @db.Timestamptz(6)
  cancelledAt           DateTime?        @map("cancelled_at") @db.Timestamptz(6)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  shift                 Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  person1               Person           @relation("AssignmentPersonOne", fields: [person1Id], references: [id], onDelete: Restrict)
  person2               Person           @relation("AssignmentPersonTwo", fields: [person2Id], references: [id], onDelete: Restrict)
  decidedByAdmin        AdminUser?       @relation(fields: [decidedByAdminId], references: [id], onDelete: SetNull)

  @@index([shiftId, status])
  @@index([person1Id])
  @@index([person2Id])
  @@map("assignments")
}

model SystemConfig {
  id                          String            @id @default(uuid()) @db.Uuid
  configKey                   String            @unique @default("default") @map("config_key")
  congregationName            String            @map("congregation_name")
  city                        String
  systemName                  String            @map("system_name")
  visibleWeeks                Int               @default(6) @map("visible_weeks")
  generateFutureWeeks         Int               @default(8) @map("generate_future_weeks")
  pinMinLength                Int               @default(4) @map("pin_min_length")
  pinMaxLength                Int               @default(8) @map("pin_max_length")
  pinMaxAttempts              Int               @default(5) @map("pin_max_attempts")
  pinLockMinutes              Int               @default(15) @map("pin_lock_minutes")
  maxRequestsPerWeek          Int               @default(4) @map("max_requests_per_week")
  maxConfirmedPerWeek         Int               @default(2) @map("max_confirmed_per_week")
  maxConfirmedPerMonth        Int               @default(6) @map("max_confirmed_per_month")
  allowConsecutiveDays        Boolean           @default(false) @map("allow_consecutive_days")
  allowMultiplePerDay         Boolean           @default(false) @map("allow_multiple_per_day")
  allowOverlapping            Boolean           @default(false) @map("allow_overlapping")
  allowSameSexPairing         Boolean           @default(true) @map("allow_same_sex_pairing")
  historyVisibility           HistoryVisibility @default(ONE_YEAR) @map("history_visibility")
  showParticipantsPublicly    Boolean           @default(false) @map("show_participants_publicly")
  showPendingRequestsPublicly Boolean           @default(false) @map("show_pending_requests_publicly")
  showFullShiftsPublicly      Boolean           @default(true) @map("show_full_shifts_publicly")
  showOpenShiftsPublicly      Boolean           @default(true) @map("show_open_shifts_publicly")
  showHistoryPublicly         Boolean           @default(false) @map("show_history_publicly")
  maintenanceModeEnabled      Boolean           @default(false) @map("maintenance_mode_enabled")
  updatedByAdminId            String?           @map("updated_by_admin_id") @db.Uuid
  createdAt                   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedByAdmin              AdminUser?        @relation("SystemConfigUpdatedByAdmin", fields: [updatedByAdminId], references: [id], onDelete: SetNull)

  @@map("system_configs")
}

model AuditLog {
  id            String         @id @default(uuid()) @db.Uuid
  actorType     AuditActorType @map("actor_type")
  entityType    String         @map("entity_type")
  entityId      String         @map("entity_id") @db.Uuid
  action        String
  actorAdminId  String?        @map("actor_admin_id") @db.Uuid
  actorPersonId String?        @map("actor_person_id") @db.Uuid
  beforeData    Json?          @map("before_data")
  afterData     Json?          @map("after_data")
  meta          Json?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  actorAdmin    AdminUser?     @relation("AuditLogActorAdmin", fields: [actorAdminId], references: [id], onDelete: SetNull)
  actorPerson   Person?        @relation("AuditLogActorPerson", fields: [actorPersonId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorType, createdAt])
  @@map("audit_logs")
}
